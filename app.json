{
  "expo": {
    "name": "AXIS",
    "slug": "AXIS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AXIS.png",
    "scheme": "auths",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/AXIS.png",
        "backgroundImage": "./assets/AXIS.png",
        "monochromeImage": "./assets/AXIS.png"
      },
      "intentFilters": [
        {
          "action": "android.intent.action.DIAL",
          "data": [
            {
              "scheme": "tel"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        },
        {
          "action": "android.intent.action.DIAL",
          "data": [
            {
              "scheme": "tel"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.AXIS"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/AXIS.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/AXIS.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
